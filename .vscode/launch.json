{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Remote Debug (gdbserver)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/the_battle_of_rogue",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "arm-none-linux-gnueabihf-gdb",
            "miDebuggerServerAddress": "${config:the_battle_of_rogue.remoteHost}:${config:the_battle_of_rogue.port}",
            "externalConsole": false,
            "preLaunchTask": "start remote gdbserver",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}